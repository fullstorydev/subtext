{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "subtext-marketplace",
  "owner": {
    "name": "Fullstory",
    "email": "support@fullstory.com"
  },
  "plugins": [
    {
      "name": "subtext-review",
      "source": "./",
      "version": "0.1.0",
      "description": "Review Fullstory session recordings and manage privacy rules",
      "category": "development",
      "keywords": [
        "subtext",
        "fullstory",
        "session-replay",
        "review",
        "privacy"
      ],
      "homepage": "https://github.com/fullstorydev/subtext-review"
    },
    {
      "name": "subtext-verify",
      "source": {
        "source": "github",
        "repo": "fullstorydev/subtext-verify"
      },
      "defaultEnabled": false,
      "description": "Drive a hosted browser, capture before/after proof, and leave reviewer-facing evidence against your running app",
      "category": "development",
      "keywords": [
        "subtext",
        "fullstory",
        "verification",
        "testing",
        "proof",
        "browser-automation"
      ],
      "homepage": "https://github.com/fullstorydev/subtext-verify"
    }
  ]
}
