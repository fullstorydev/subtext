#!/usr/bin/env bash
# One-time setup: create a Python venv and install dependencies.
# Re-run safely — idempotent.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HARNESS_DIR="$(dirname "$SCRIPT_DIR")"
VENV="$HARNESS_DIR/venv"

PYTHON_BIN="${PYTHON_BIN:-python3}"

if [ ! -d "$VENV" ]; then
  echo "Creating venv at $VENV"
  "$PYTHON_BIN" -m venv "$VENV"
fi

# shellcheck disable=SC1091
source "$VENV/bin/activate"

pip install --quiet --upgrade pip
pip install --quiet -r "$HARNESS_DIR/requirements.txt"

echo "Setup complete."
echo "  venv:     $VENV"
echo "  anthropic: $(python -c 'import anthropic; print(anthropic.__version__)')"
