{
  "name": "subtext",
  "version": "0.2.4",
  "description": "Tools that let coding agents verify and show their work against your running application",
  "mcpServers": {
    "subtext": {
      "type": "http",
      "url": "https://api.fullstory.com/mcp/subtext",
      "oauth": {
        "scopes": ["sessions:read"]
      }
    },
    "subtext-eu1": {
      "type": "http",
      "url": "https://api.eu1.fullstory.com/mcp/subtext",
      "oauth": {
        "scopes": ["sessions:read"]
      }
    },
    "subtext-tunnel": {
      "command": "npx",
      "args": ["-y", "@fullstory/subtext-tunnel@latest"]
    }
  },
  "contextFileName": "GEMINI.md"
}
