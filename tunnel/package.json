{
  "name": "@fullstory/subtext-tunnel",
  "version": "0.1.11",
  "description": "MCP server for reverse tunneling to localhost — connects hosted Subtext browser tools to local dev servers.",
  "type": "module",
  "bin": {
    "subtext-tunnel": "./build/src/index.js"
  },
  "files": [
    "build/src/"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('build', {recursive: true, force: true})\"",
    "build": "tsc",
    "bundle": "npm run clean && npm run build && rollup -c rollup.config.mjs",
    "test": "node --test build/tests/**/*.js",
    "prepublishOnly": "npm run bundle"
  },
  "keywords": [
    "mcp",
    "fullstory",
    "subtext",
    "tunnel"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fullstorydev/subtext.git",
    "directory": "tunnel"
  },
  "homepage": "https://github.com/fullstorydev/subtext/tree/main/tunnel",
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.0",
    "@types/yargs": "^17.0.35",
    "rollup": "^4.60.1",
    "rollup-plugin-cleanup": "^3.2.1",
    "typescript": "^5.9.2",
    "ws": "^8.18.0",
    "yargs": "18.0.0"
  },
  "engines": {
    "node": "^20.11.0 || ^22.12.0 || >=23"
  }
}
